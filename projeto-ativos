import sqlite3
from enum import Enum

ARQUIVO_DB = "inventario_seguranca.db"

def conectar_banco():
    conn = sqlite3.connect(ARQUIVO_DB)
    conn.execute("PRAGMA foreign_keys = ON;")
    conn.row_factory = sqlite3.Row
    return conn, conn.cursor()

def inicializar_banco():
    conn, cursor = conectar_banco()
    
    cursor.execute("""
    CREATE TABLE IF NOT EXISTS ativos (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        nome TEXT NOT NULL,
        tipo TEXT NOT NULL,
        localizacao TEXT NOT NULL,
        responsavel TEXT NOT NULL
    );
    """)
    
    cursor.execute("""
    CREATE TABLE IF NOT EXISTS vulnerabilidades (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        descricao TEXT NOT NULL,
        severidade TEXT NOT NULL,
        status TEXT NOT NULL,
        responsavel_correcao TEXT,
        ativo_id INTEGER NOT NULL,
        FOREIGN KEY (ativo_id) REFERENCES ativos (id) ON DELETE CASCADE
    );
    """)
    
    conn.commit()
    conn.close()

class TipoAtivo(Enum):
    NOTEBOOKS = 1
    SERVIDORES = 2
    ESTACOES_DE_TRABALHO = 3
    ROTEADORES = 4
    IMPRESSORAS_DE_REDE = 5
    SISTEMAS_INTERNOS = 6
    SOFTWARES_LICENCIADOS = 7
    APLICACOES_WEB = 8
    BANCOS_DE_DADOS = 9

class Severidade(Enum):
    BAIXA = 1
    MEDIA = 2
    ALTA = 3
    CRITICA = 4

class StatusVuln(Enum):
    ABERTA = 1
    EM_TRATAMENTO = 2
    CORRIGIDA = 3
    ACEITA_COMO_RISCO = 4

def coletar_dados_vulnerabilidade():
    print("\n[Dica: Digite 'v' para voltar]")
    desc = input("Descrição da vulnerabilidade: ").strip()
    if desc.lower() == "v": return None

    while True:
        print("\nNíveis de Severidade:")
        for sev in Severidade:
            print(f"{sev.value} - {sev.name.capitalize()}")
        s_input = input("Escolha o código da severidade: ").strip()
        if s_input.lower() == "v": return None
        try:
            s_cod = int(s_input)
            severidade_nome = Severidade(s_cod).name.capitalize()
            break
        except ValueError:
            print("[!] Código inválido.")

    while True:
        print("\nStatus da Vulnerabilidade:")
        for st in StatusVuln:
            nome_exibicao = st.name.replace("_", " ").capitalize()
            print(f"{st.value} - {nome_exibicao}")
        st_input = input("Escolha o código do status: ").strip()
        if st_input.lower() == "v": return None
        try:
            st_cod = int(st_input)
            status_enum = StatusVuln(st_cod)
            status_nome = status_enum.name.replace("_", " ").capitalize()
            break
        except ValueError:
            print("[!] Código inválido.")

    responsavel_corr = None
    if status_enum in [StatusVuln.CORRIGIDA, StatusVuln.EM_TRATAMENTO]:
        responsavel_corr = input("Nome do responsável pela ação/correção: ").strip()
        if responsavel_corr.lower() == "v": return None

    return {"descricao": desc, "severidade": severidade_nome, "status": status_nome, "responsavel_correcao": responsavel_corr}

def cadastrar_ativo():
    print("\n--- NOVO CADASTRO ---")
    print("[Dica: Digite 'v' para voltar]")
    
    nome = input("Nome/Hostname do Ativo: ").strip()
    if nome.lower() == "v": return
    
    responsavel = input("Responsável: ").strip()
    if responsavel.lower() == "v": return
    
    local = input("Setor/Localização: ").strip()
    if local.lower() == "v": return

    while True:
        print("\nCategorias de Ativos:")
        for tipo in TipoAtivo:
            nome_exibicao = tipo.name.replace("_", " ").capitalize()
            print(f"{tipo.value} - {nome_exibicao}")
        t_input = input("Escolha o código da categoria: ").strip()
        if t_input.lower() == "v": return
        try:
            t_cod = int(t_input)
            tipo_nome = TipoAtivo(t_cod).name.replace("_", " ").capitalize()
            break
        except ValueError:
            print("[!] Categoria inválida.")

    conn, cursor = conectar_banco()
    
    cursor.execute("""
        INSERT INTO ativos (nome, tipo, localizacao, responsavel)
        VALUES (?, ?, ?, ?);
    """, (nome, tipo_nome, local, responsavel))
    
    ativo_id = cursor.lastrowid

    while True:
        opcao_vuln = input("Deseja adicionar uma vulnerabilidade inicial? (S/N): ").strip().lower()
        if opcao_vuln == "s":
            v = coletar_dados_vulnerabilidade()
            if v:
                cursor.execute("""
                    INSERT INTO vulnerabilidades (descricao, severidade, status, responsavel_correcao, ativo_id)
                    VALUES (?, ?, ?, ?, ?);
                """, (v['descricao'], v['severidade'], v['status'], v['responsavel_correcao'], ativo_id))
                print("[+] Vulnerabilidade registrada.")
            break
        elif opcao_vuln in ["n", "v"]:
            break
        else:
            print("[!] Digite apenas S ou N.")

    conn.commit()
    conn.close()
    print(f"\n[+] Ativo cadastrado com sucesso! ID Gerado: {ativo_id}\n")

def mostrar_indice():
    conn, cursor = conectar_banco()
    cursor.execute("SELECT id, nome FROM ativos ORDER BY id;")
    ativos = cursor.fetchall()
    conn.close()

    if not ativos:
        print("\n[!] Nenhum ativo cadastrado no banco de dados.")
        return False
        
    print("\n--- LISTA DE ATIVOS ---")
    print(f"{'ID':<6} | {'NOME/HOSTNAME':<20}")
    print("-" * 35)
    for ativo in ativos:
        print(f"{ativo['id']:<6} | {ativo['nome']:<20}")
    return True

def consultar_ativo():
    print("\n--- CONSULTA DE ATIVOS ---")
    termo = input("Digite parte do nome (Enter para listar todos): ").strip()
    
    conn, cursor = conectar_banco()
    cursor.execute("SELECT id, nome FROM ativos WHERE nome LIKE ?;", (f"%{termo}%",))
    encontrados = cursor.fetchall()

    if not encontrados:
        print("[!] Nenhum resultado encontrado.")
        conn.close()
        return

    print("\n--- RESULTADOS ---")
    for ativo in encontrados:
        print(f"{ativo['id']} - {ativo['nome']}")

    while True:
        escolha = input("\nDigite o ID para detalhes (ou 'v'): ").strip()
        if escolha.lower() == "v": 
            conn.close()
            return
        try:
            escolha_id = int(escolha)
            cursor.execute("SELECT * FROM ativos WHERE id = ?;", (escolha_id,))
            ativo = cursor.fetchone()
            
            if ativo:
                print(f"\n==========================================")
                print(f"DETALHES DO ATIVO #{ativo['id']}")
                print(f"==========================================")
                print(f"Nome/Hostname:      {ativo['nome']}")
                print(f"Tipo/Categoria:     {ativo['tipo']}")
                print(f"Localização/Setor:  {ativo['localizacao']}")
                print(f"Responsável Geral:  {ativo['responsavel']}")
                print(f"------------------------------------------")
                print("Vulnerabilidades Registradas:")
                print(f"------------------------------------------")
                
                cursor.execute("SELECT * FROM vulnerabilidades WHERE ativo_id = ?;", (escolha_id,))
                vulnerabilidades = cursor.fetchall()
                
                if vulnerabilidades:
                    for v in vulnerabilidades:
                        info_corr = f" (Responsável: {v['responsavel_correcao']})" if v['responsavel_correcao'] else ""
                        print(f" -> [{v['severidade'].upper()}] {v['descricao']}")
                        print(f"    Status de Tratamento: {v['status']}{info_corr}\n")
                else:
                    print(" -> Nenhuma vulnerabilidade encontrada para este ativo.")
                print(f"==========================================")
                break
            else:
                print("[!] ID inválido.")
        except ValueError:
            print("[!] Digite um número válido.")
            
    conn.close()

def gerenciar_vulnerabilidades_ativo():
    if not mostrar_indice(): return
    
    while True:
        id_input = input("\nID do ativo para gerenciar (ou 'v' para voltar): ").strip()
        if id_input.lower() == "v": return
        try:
            id_at = int(id_input)
            conn, cursor = conectar_banco()
            cursor.execute("SELECT * FROM ativos WHERE id = ?;", (id_at,))
            ativo = cursor.fetchone()
            if ativo: break
            print("[!] Ativo não encontrado.")
            conn.close()
        except ValueError:
            print("[!] ID inválido.")

    print(f"\nO que deseja fazer no ativo '{ativo['nome']}'?")
    print("1. Adicionar nova vulnerabilidade")
    print("2. Modificar status de uma vulnerabilidade")
    print("3. Editar dados estruturais do ativo")
    print("v. Voltar")
    opcao = input("Escolha uma opção: ").strip()
    if opcao.lower() == "v": 
        conn.close()
        return

    if opcao == "1":
        v = coletar_dados_vulnerabilidade()
        if v:
            cursor.execute("""
                INSERT INTO vulnerabilidades (descricao, severidade, status, responsavel_correcao, ativo_id)
                VALUES (?, ?, ?, ?, ?);
            """, (v['descricao'], v['severidade'], v['status'], v['responsavel_correcao'], id_at))
            conn.commit()
            print("[+] Nova vulnerabilidade adicionada ao banco.")
            
    elif opcao == "2":
        cursor.execute("SELECT * FROM vulnerabilidades WHERE ativo_id = ?;", (id_at,))
        vulnerabilidades = cursor.fetchall()
        
        if not vulnerabilidades:
            print("[!] Não há vulnerabilidades para modificar.")
            conn.close()
            return
        
        print("\nVulnerabilidades atuais:")
        for i, v in enumerate(vulnerabilidades, start=1):
            print(f"{i} - [{v['severidade'].upper()}] {v['descricao']} (Status: {v['status']})")
            
        while True:
            idx_input = input("Número do item (ou 'v'): ").strip()
            if idx_input.lower() == "v": 
                conn.close()
                return
            try:
                idx = int(idx_input) - 1
                if 0 <= idx < len(vulnerabilidades): break
                print("[!] Item inválido.")
            except ValueError:
                print("[!] Digite um número.")
                
        vuln_selecionada = vulnerabilidades[idx]
        
        while True:
            print("\nNovo Status:")
            for st in StatusVuln:
                print(f"{st.value} - {st.name.replace('_', ' ').capitalize()}")
            st_input = input("Escolha o status: ").strip()
            if st_input.lower() == "v": 
                conn.close()
                return
            try:
                st_cod = int(st_input)
                status_enum = StatusVuln(st_cod)
                break
            except ValueError:
                print("[!] Código inválido.")
                
        novo_status = status_enum.name.replace("_", " ").capitalize()
        
        responsavel_acao = None
        if status_enum in [StatusVuln.CORRIGIDA, StatusVuln.EM_TRATAMENTO]:
            responsavel_acao = input("Nome do responsável pela ação: ").strip()
            
        cursor.execute("""
            UPDATE vulnerabilidades 
            SET status = ?, responsavel_correcao = ? 
            WHERE id = ?;
        """, (novo_status, responsavel_acao, vuln_selecionada['id']))
        conn.commit()
        print("[+] Status updated com sucesso no SQLite.")

    elif opcao == "3":
        print(f"\n--- ATUALIZAR DADOS DO ATIVO #{ativo['id']} ---")
        print("[Dica: Pressione Enter sem digitar nada para manter o dado atual]")
        
        novo_nome = input(f"Nome atual [{ativo['nome']}]: ").strip()
        if novo_nome == "": novo_nome = ativo['nome']

        novo_resp = input(f"Responsável active [{ativo['responsavel']}]: ").strip()
        if novo_resp == "": novo_resp = ativo['responsavel']

        nova_local = input(f"Localização atual [{ativo['localizacao']}]: ").strip()
        if nova_local == "": nova_local = ativo['localizacao']

        cursor.execute("""
            UPDATE ativos 
            SET nome = ?, responsavel = ?, localizacao = ? 
            WHERE id = ?;
        """, (novo_nome, novo_resp, nova_local, ativo['id']))
        conn.commit()
        print("[+] Dados estruturais atualizados com sucesso!")
        
    conn.close()

def remover_ativo():
    if not mostrar_indice(): return
    while True:
        id_input = input("\nID do ativo para remover definitivamente (ou 'v'): ").strip()
        if id_input.lower() == "v": return
        try:
            id_at = int(id_input)
            conn, cursor = conectar_banco()
            
            cursor.execute("SELECT id FROM ativos WHERE id = ?;", (id_at,))
            if cursor.fetchone():
                cursor.execute("DELETE FROM ativos WHERE id = ?;", (id_at,))
                conn.commit()
                print("[+] Ativo e todas as vulnerabilidades vinculadas foram removidos via CASCADE.")
                conn.close()
                break
            print("[!] ID não encontrado.")
            conn.close()
        except ValueError:
            print("[!] Digite um número válido.")

def menu():
    inicializar_banco()
    while True:
        print("\n===== SISTEMA DE INVENTÁRIO TI (SQLITE NATIVO) =====")
        print("1. Cadastrar Ativo")
        print("2. Listar e Consultar Ativos")
        print("3. Gerenciar Ativo (Vulnerabilidades / Dados)")
        print("4. Remover Ativo")
        print("0. Sair")
        opcao = input("\nSelecione: ").strip()

        if opcao == "1": cadastrar_ativo()
        elif opcao == "2": consultar_ativo()
        elif opcao == "3": gerenciar_vulnerabilidades_ativo()
        elif opcao == "4": remover_ativo()
        elif opcao == "0":
            print("\n======= PROGRAMA FINALIZADO =======")
            break
        else:
            print("[!] Opção inválida.")

if __name__ == "__main__":
    menu()